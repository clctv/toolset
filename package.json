{
  "name": "@clctv/toolset",
  "version": "0.1.3",
  "description": "Opinionated CLI to bootstrap JS/TS project tooling fast",
  "keywords": [
    "bootstrap",
    "cli",
    "javascript",
    "project-setup",
    "scaffold",
    "tooling",
    "toolset",
    "typescript"
  ],
  "license": "MIT",
  "repository": "clctv/toolset",
  "bin": {
    "toolset": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "release": "release-it --only-version",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "package-manager-detector": "^1.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@rslib/core": "^0.20.0",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "picocolors": "^1.1.1",
    "release-it": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "hooks": {
      "before:init": [
        "pnpm run build"
      ]
    },
    "git": {
      "commitMessage": "chore: release v${version}"
    },
    "github": {
      "release": true,
      "releaseName": "v${version}",
      "web": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md",
        "ignoreRecommendedBump": true
      }
    }
  }
}
